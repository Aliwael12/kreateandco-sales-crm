# Copy this to migration/.env (gitignored) and fill in the connection string.
# import.mjs and verify.mjs auto-load migration/.env, so once this is set you
# never paste secrets into the shell.
#
# Get the URI from: Supabase Dashboard → Project Settings → Database →
# Connection string → "URI" (use the direct connection, port 5432, and include
# the database password). Example shape:
#   SUPABASE_DB_URL=postgresql://postgres:<DB_PASSWORD>@db.qhcptigbbhrnxgechsrl.supabase.co:5432/postgres
SUPABASE_DB_URL=
